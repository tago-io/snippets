{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    ".astro/**",
    ".playwright-mcp/**",
    "pnpm-lock.yaml",
    "src/data/**",
    "snippets/**/*.py",
    "snippet-browse-layout.png"
  ]
}
