{
  "name": "@tago-io/snippets",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "preinstall": "node -e \"if(!/pnpm/.test(process.env.npm_execpath||'')){console.error('Use pnpm install (npm and yarn are not supported).');process.exit(1)}\"",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "tsx scripts/prepare-data.ts && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "fmt": "oxfmt . && ruff format snippets/analysis/",
    "fmt:js": "oxfmt .",
    "fmt:py": "ruff format snippets/analysis/",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint . && ruff check snippets/analysis/",
    "lint:js": "oxlint .",
    "lint:py": "ruff check snippets/analysis/",
    "lint:fix": "oxlint --fix . && ruff check --fix snippets/analysis/",
    "check": "oxlint --deny-warnings . && oxfmt --check . && ruff check snippets/analysis/"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.3.0",
    "@fontsource/monaspace-neon": "^5.3.0",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.3",
    "tailwindcss": "^4.3.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
