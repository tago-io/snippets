---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="TagoIO Snippets">
  <main class="container max-w-6xl mx-auto px-4 pt-6 pb-16">
    <header class="text-center mb-12">
      <p class="text-xs font-medium tracking-[0.3em] uppercase text-muted-foreground mb-3">
        Catalog
      </p>
      <h1 class="text-3xl font-semibold tracking-tight mb-3">TagoIO Snippets</h1>
      <p class="text-sm text-muted-foreground max-w-xl mx-auto">
        Code samples for Analysis, Payload Parser, and TagoSQL.
      </p>
    </header>

    <!-- Analysis Snippets Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-4">Analysis</h2>
      <p class="text-muted-foreground mb-8">
        Analysis scripts run on TagoIO's serverless platform to process device data, send
        notifications, generate reports, and integrate with external services.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Node Legacy -->
        <div class="border border-border bg-card rounded-lg p-6">
          <div class="flex items-center justify-between gap-4 mb-4">
            <h3 class="text-lg font-semibold">Node.js Legacy</h3>
            <span class="px-3 py-1 bg-muted text-muted-foreground text-xs rounded-full shrink-0">
              Legacy
            </span>
          </div>
          <p class="text-sm text-muted-foreground mb-8">
            ES5/ES6 JavaScript with pre-installed libraries only
          </p>
          <div class="flex flex-col gap-2">
            <a href="/analysis/node-legacy/" class="text-info hover:underline text-sm font-medium">
              Browse files
            </a>
            <a href="/analysis/node-legacy.json" class="text-muted-foreground hover:underline text-sm">
              JSON metadata
            </a>
          </div>
        </div>

        <!-- Node rt2025 -->
        <div class="border border-border bg-card rounded-lg p-6">
          <div class="flex items-center justify-between gap-4 mb-4">
            <h3 class="text-lg font-semibold">Node.js rt2025</h3>
            <span class="px-3 py-1 bg-muted text-muted-foreground text-xs rounded-full shrink-0">
              Modern
            </span>
          </div>
          <p class="text-sm text-muted-foreground mb-8">
            Modern JavaScript with fetch API and improved performance
          </p>
          <div class="flex flex-col gap-2">
            <a href="/analysis/node-rt2025/" class="text-info hover:underline text-sm font-medium">
              Browse files
            </a>
            <a href="/analysis/node-rt2025.json" class="text-muted-foreground hover:underline text-sm">
              JSON metadata
            </a>
          </div>
        </div>

        <!-- Deno rt2025 -->
        <div class="border border-border bg-card rounded-lg p-6">
          <div class="flex items-center justify-between gap-4 mb-4">
            <h3 class="text-lg font-semibold">Deno rt2025</h3>
            <span class="px-3 py-1 bg-muted text-muted-foreground text-xs rounded-full shrink-0">
              TypeScript
            </span>
          </div>
          <p class="text-sm text-muted-foreground mb-8">
            Modern TypeScript/JavaScript with native TS support and URL-based modules
          </p>
          <div class="flex flex-col gap-2">
            <a href="/analysis/deno-rt2025/" class="text-info hover:underline text-sm font-medium">
              Browse files
            </a>
            <a href="/analysis/deno-rt2025.json" class="text-muted-foreground hover:underline text-sm">
              JSON metadata
            </a>
          </div>
        </div>

        <!-- Python Legacy -->
        <div class="border border-border bg-card rounded-lg p-6">
          <div class="flex items-center justify-between gap-4 mb-4">
            <h3 class="text-lg font-semibold">Python Legacy</h3>
            <span class="px-3 py-1 bg-muted text-muted-foreground text-xs rounded-full shrink-0">
              Legacy
            </span>
          </div>
          <p class="text-sm text-muted-foreground mb-8">
            Python 3.x with pre-installed libraries only
          </p>
          <div class="flex flex-col gap-2">
            <a href="/analysis/python-legacy/" class="text-info hover:underline text-sm font-medium">
              Browse files
            </a>
            <a href="/analysis/python-legacy.json" class="text-muted-foreground hover:underline text-sm">
              JSON metadata
            </a>
          </div>
        </div>

        <!-- Python rt2025 -->
        <div class="border border-border bg-card rounded-lg p-6">
          <div class="flex items-center justify-between gap-4 mb-4">
            <h3 class="text-lg font-semibold">Python rt2025</h3>
            <span class="px-3 py-1 bg-muted text-muted-foreground text-xs rounded-full shrink-0">
              Modern
            </span>
          </div>
          <p class="text-sm text-muted-foreground mb-8">
            Latest Python with dynamic package installation (UV) and PyPI access
          </p>
          <div class="flex flex-col gap-2">
            <a href="/analysis/python-rt2025/" class="text-info hover:underline text-sm font-medium">
              Browse files
            </a>
            <a href="/analysis/python-rt2025.json" class="text-muted-foreground hover:underline text-sm">
              JSON metadata
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Payload Parser Snippets Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-4">Payload Parser</h2>
      <p class="text-muted-foreground mb-8">
        Payload parsers transform raw device data into TagoIO's standardized format for storage
        and visualization.
      </p>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="border border-border bg-card rounded-lg p-6">
          <div class="flex items-center justify-between gap-4 mb-4">
            <h3 class="text-lg font-semibold">JavaScript Runtime</h3>
            <span class="px-3 py-1 bg-muted text-muted-foreground text-xs rounded-full shrink-0">
              Node.js
            </span>
          </div>
          <p class="text-sm text-muted-foreground mb-8">
            JavaScript (ES5/ES6+) for processing and transforming device payload data
          </p>
          <div class="flex flex-col gap-2">
            <a href="/payload-parser/javascript/" class="text-info hover:underline text-sm font-medium">
              Browse files
            </a>
            <a
              href="/payload-parser/javascript.json"
              class="text-muted-foreground hover:underline text-sm"
            >
              JSON metadata
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- TagoSQL Snippets Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-4">TagoSQL</h2>
      <p class="text-muted-foreground mb-8">
        Ready-to-use TagoSQL queries for the /sql routes of the TagoIO API, from a simple device
        read to fleet-wide queries by tag.
      </p>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="border border-border bg-card rounded-lg p-6">
          <div class="flex items-center justify-between gap-4 mb-4">
            <h3 class="text-lg font-semibold">SQL</h3>
            <span class="px-3 py-1 bg-muted text-muted-foreground text-xs rounded-full shrink-0">
              TagoSQL
            </span>
          </div>
          <p class="text-sm text-muted-foreground mb-8">
            Read-only SQL over your device and entity data, with positional parameters
          </p>
          <div class="flex flex-col gap-2">
            <a href="/tagosql/sql/" class="text-info hover:underline text-sm font-medium">
              Browse files
            </a>
            <a href="/tagosql/sql.json" class="text-muted-foreground hover:underline text-sm">
              JSON metadata
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Usage Examples Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-8">Usage examples</h2>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="border border-border bg-card rounded-lg p-6">
          <h3 class="text-base font-semibold mb-4">Fetch JSON metadata</h3>
          <pre class="text-sm font-mono bg-muted border border-border rounded-lg p-4 overflow-x-auto"><code>curl https://snippets.tago.io/analysis/deno-rt2025.json</code></pre>
        </div>

        <div class="border border-border bg-card rounded-lg p-6">
          <h3 class="text-base font-semibold mb-4">Download code file</h3>
          <pre class="text-sm font-mono bg-muted border border-border rounded-lg p-4 overflow-x-auto"><code>curl https://snippets.tago.io/analysis/deno-rt2025/console.ts</code></pre>
        </div>
      </div>
    </section>

    <!-- API Endpoints Section -->
    <section class="mb-16">
      <h2 class="text-2xl font-semibold mb-8">API endpoints</h2>

      <div class="space-y-8">
        <div>
          <h3 class="text-base font-semibold mb-4">Analysis</h3>
          <div class="bg-muted border border-border rounded-lg p-4">
            <div class="grid gap-2 text-sm font-mono">
              <div><span class="text-muted-foreground">JSON:</span> /analysis/&#123;runtime&#125;.json</div>
              <div><span class="text-muted-foreground">Files:</span> /analysis/&#123;runtime&#125;/&#123;filename&#125;</div>
              <div class="text-xs text-muted-foreground mt-2 font-sans">
                Runtimes: node-legacy, node-rt2025, deno-rt2025, python-legacy, python-rt2025
              </div>
            </div>
          </div>
        </div>

        <div>
          <h3 class="text-base font-semibold mb-4">Payload Parser</h3>
          <div class="bg-muted border border-border rounded-lg p-4">
            <div class="grid gap-2 text-sm font-mono">
              <div><span class="text-muted-foreground">JSON:</span> /payload-parser/&#123;runtime&#125;.json</div>
              <div><span class="text-muted-foreground">Files:</span> /payload-parser/&#123;runtime&#125;/&#123;filename&#125;</div>
              <div class="text-xs text-muted-foreground mt-2 font-sans">
                Runtimes: javascript
              </div>
            </div>
          </div>
        </div>

        <div>
          <h3 class="text-base font-semibold mb-4">TagoSQL</h3>
          <div class="bg-muted border border-border rounded-lg p-4">
            <div class="grid gap-2 text-sm font-mono">
              <div><span class="text-muted-foreground">JSON:</span> /tagosql/sql.json</div>
              <div><span class="text-muted-foreground">Files:</span> /tagosql/sql/&#123;filename&#125;</div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </main>
</BaseLayout>
