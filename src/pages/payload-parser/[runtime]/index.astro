---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SnippetCard from "../../../components/SnippetCard.astro";
import { PAYLOAD_PARSER_RUNTIMES, collectSnippets } from "../../../lib/snippets.ts";

export async function getStaticPaths() {
  const paths = [];

  for (const runtime of PAYLOAD_PARSER_RUNTIMES) {
    const snippets = await collectSnippets(runtime);

    paths.push({
      params: { runtime: runtime.name },
      props: {
        runtime,
        snippets,
      },
    });
  }

  return paths;
}

const { runtime, snippets } = Astro.props;
const jsonName = `${runtime.name}.json`;
---

<BaseLayout title={`${runtime.displayName} • Payload Parser • TagoIO Snippets`}>
  <main class="container max-w-5xl mx-auto px-4 pt-6 pb-16 min-w-0">
    <div class="mb-8">
      <nav class="text-sm text-muted-foreground mb-4">
        <a href="/" class="text-info hover:underline">Home</a>
        <span class="mx-2">/</span>
        <span>Payload Parser</span>
        <span class="mx-2">/</span>
        <span>{runtime.displayName}</span>
      </nav>

      <h1 class="text-3xl font-semibold mb-4">{runtime.displayName} Payload Parser snippets</h1>
      <p class="text-muted-foreground mb-8">
        Browse all available payload parser snippets for the {runtime.displayName} runtime.
      </p>

      <div class="flex flex-wrap gap-4 mb-8">
        <a
          href={`/payload-parser/${runtime.name}.json`}
          download={jsonName}
          class="inline-flex items-center px-6 py-2 rounded-full bg-primary text-primary-foreground hover:bg-primary/90 text-sm font-medium"
        >
          Download JSON metadata
        </a>
      </div>

      {
        snippets.length > 3 && (
          <nav
            class="mb-8 p-4 border border-border bg-card rounded-lg"
            aria-label="Snippet index"
          >
            <p class="text-xs font-medium uppercase tracking-wide text-muted-foreground mb-3">
              On this page
            </p>
            <ul class="flex flex-wrap gap-x-4 gap-y-2 list-none m-0 p-0">
              {snippets.map((snippet) => (
                <li>
                  <a href={`#${snippet.id}`} class="text-info hover:underline text-sm">
                    {snippet.title}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )
      }
    </div>

    <div class="min-h-64">
      {
        snippets.length > 0 ? (
          <div class="grid gap-8 min-w-0">
            {snippets.map((snippet) => (
              <SnippetCard
                id={snippet.id}
                title={snippet.title}
                description={snippet.description}
                tags={snippet.tags}
                filename={snippet.filename}
                language={snippet.language}
                code={snippet.code}
                fileHref={`/payload-parser/${runtime.name}/${snippet.filename}`}
              />
            ))}
          </div>
        ) : (
          <div class="flex items-center justify-center min-h-64 border border-border bg-card rounded-lg p-6">
            <p class="text-muted-foreground">No snippets available for this runtime.</p>
          </div>
        )
      }
    </div>

    <div class="mt-16 text-center">
      <a href="/" class="text-info hover:underline text-sm">Back to home</a>
    </div>
  </main>
</BaseLayout>
